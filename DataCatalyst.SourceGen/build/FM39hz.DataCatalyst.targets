<Project>
  <PropertyGroup>
    <ModsDirectory Condition="'$(ModsDirectory)' == ''">Mods</ModsDirectory>
    <EnableModMerge Condition="'$(EnableModMerge)' == ''">false</EnableModMerge>
  </PropertyGroup>

  <Target Name="DiscoverMods" BeforeTargets="CoreCompile"
          Condition="'$(EnableModMerge)' == 'true' And Exists('$(ModsDirectory)')">
    <ItemGroup>
      <_ModDir Include="$([System.IO.Directory]::GetDirectories('$(ModsDirectory)'))" />
    </ItemGroup>

    <ItemGroup>
      <ModSource Include="%(Identity)/**/*.cs" Condition="Exists('%(Identity)/mod.json')" />
      <ModData Include="%(Identity)/**/*.json" Exclude="%(Identity)/mod.json" Condition="Exists('%(Identity)/mod.json')" />
    </ItemGroup>

    <ItemGroup>
      <Compile Include="@(ModSource)" />
      <AdditionalFiles Include="@(ModData)" />
    </ItemGroup>

    <Message Text="DataCatalyst: merged @(ModSource->Count()) source files, @(ModData->Count()) data files from $(ModsDirectory)"
             Importance="High" />
  </Target>
</Project>
