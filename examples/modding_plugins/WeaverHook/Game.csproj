    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <EnableModHookWeaver>true</EnableModHookWeaver>
    <ModHookIncludePattern>^(Game\..*)$</ModHookIncludePattern>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FM39hz.DataCatalyst" />
    <PackageReference Include="FM39hz.DataCatalyst.Plugins.Modding" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="Data\*.json" />
  </ItemGroup>
</Project>
