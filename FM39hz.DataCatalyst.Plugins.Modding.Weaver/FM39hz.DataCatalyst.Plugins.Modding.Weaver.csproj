<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>FM39hz.DataCatalyst.Plugins.Modding.Weaver</RootNamespace>
    <AssemblyName>FM39hz.DataCatalyst.Plugins.Modding.Weaver</AssemblyName>
    <Description>DataCatalyst Modding IL weaver — Mono.Cecil MSBuild task for [ModHook] injection.</Description>
    <PackageTags>data-catalyst;modding;weaver;mono-cecil</PackageTags>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <NoWarn>$(NoWarn);NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Mono.Cecil" PrivateAssets="all" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FM39hz.DataCatalyst.Plugins.Modding.Runtime\FM39hz.DataCatalyst.Plugins.Modding.Runtime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="build/**" PackagePath="build/" />
  </ItemGroup>

  <Target Name="CopyToBuildOutput" BeforeTargets="GenerateNuspec" Condition="'$(PackageId)' != ''">
    <ItemGroup>
      <_TaskFiles Include="$(OutputPath)*.dll;$(OutputPath)*.pdb;$(OutputPath)*.xml" />
    </ItemGroup>
    <Copy SourceFiles="@(_TaskFiles)" DestinationFolder="$(MSBuildProjectDirectory)\build\netstandard2.0\" />
  </Target>

  <Target Name="CleanBuildOutput" AfterTargets="Clean">
    <RemoveDir Directories="$(MSBuildProjectDirectory)\build\netstandard2.0\" />
  </Target>
</Project>
