<Project>
  <PropertyGroup>
    <EnableModHookWeaver Condition="'$(EnableModHookWeaver)' == ''">false</EnableModHookWeaver>
    <ModHookIncludePattern Condition="'$(ModHookIncludePattern)' == ''">.*</ModHookIncludePattern>
    <ModHookExcludePattern Condition="'$(ModHookExcludePattern)' == ''">^(.*\.(get_|set_|add_|remove_)|.*c__DisplayClass)</ModHookExcludePattern>
  </PropertyGroup>

  <UsingTask
    TaskName="FM39hz.DataCatalyst.Plugins.Modding.Weaver.WeaverTask"
    AssemblyFile="$(MSBuildThisFileDirectory)netstandard2.0\FM39hz.DataCatalyst.Plugins.Modding.Weaver.dll" />

  <Target Name="DataCatalystWeave"
          AfterTargets="CoreCompile"
          BeforeTargets="NativeAOT;LinkNative;ILLink"
          Condition="'$(EnableModHookWeaver)' == 'true' Or '$(DesignTimeBuild)' != 'true'">

    <WeaverTask
      AssemblyPath="$(IntermediateOutputPath)$(TargetFileName)"
      ReferencePath="@(ReferencePath)"
      EnableModHookWeaver="$(EnableModHookWeaver)"
      ModHookIncludePattern="$(ModHookIncludePattern)"
      ModHookExcludePattern="$(ModHookExcludePattern)"
      Condition="Exists('$(IntermediateOutputPath)$(TargetFileName)')" />
  </Target>
</Project>
