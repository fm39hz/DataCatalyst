<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PublishAot>true</PublishAot>
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	</PropertyGroup>
	<ItemGroup>
		<AdditionalFiles Include="Data/**/*.json" />
		<AdditionalFiles Include="Metadata/**/*.json" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\DataCatalyst.Abstractions\DataCatalyst.Abstractions.csproj" />
		<ProjectReference Include="..\DataCatalyst.Core\DataCatalyst.Core.csproj" />
		<ProjectReference Include="..\DataCatalyst.Loaders.Json\DataCatalyst.Loaders.Json.csproj" />
		<ProjectReference Include="..\DataCatalyst.SourceGen\DataCatalyst.SourceGen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\DataCatalyst.SourceGen\DataCatalyst.SourceGen.csproj" ReferenceOutputAssembly="true" />
		<ProjectReference Include="..\DataCatalyst.Extensions\DataCatalyst.Extensions.csproj" />
		<ProjectReference Include="..\DataCatalyst.Plugins.StateEngine\DataCatalyst.Plugins.StateEngine.csproj" />
	</ItemGroup>
	<ItemGroup>
	  <PackageReference Include="Arch" />
	</ItemGroup>
</Project>
