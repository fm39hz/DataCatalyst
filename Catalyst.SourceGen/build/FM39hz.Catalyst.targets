<Project>
	<PropertyGroup>
		<ModsDirectory Condition="'$(ModsDirectory)' == ''">Mods</ModsDirectory>
		<EnableModMerge Condition="'$(EnableModMerge)' == ''">false</EnableModMerge>
	</PropertyGroup>

	<Target Name="DiscoverMods" BeforeTargets="CoreCompile"
	        Condition="'$(EnableModMerge)' == 'true' And Exists('$(ModsDirectory)')">
		<ItemGroup>
			<_ModDir Include="$([System.IO.Directory]::GetDirectories('$(ModsDirectory)'))"/>
		</ItemGroup>

		<ItemGroup>
			<ModData Include="%(Identity)/**/*.json" Condition="Exists('%(Identity)/mod.json')"/>
		</ItemGroup>

		<ItemGroup>
			<AdditionalFiles Include="@(ModData)"/>
		</ItemGroup>

		<Message Text="Catalyst: merged @(ModData->Count()) data files from $(ModsDirectory)"
		         Importance="High"/>
	</Target>
</Project>
